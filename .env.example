# Sao chép file này thành .env cho máy cục bộ. Không commit file .env.
# Chỉ điền secret tại máy/deployment tương ứng; không gửi secret qua issue hoặc PR.

APP_ENV=development
APP_PORT=3000

# Cấu hình AI tùy kiến trúc đã chốt. Không ghi key thật ở đây.
AI_PROVIDER=
AI_MODEL=
AI_API_KEY=
AI_BASE_URL=

# Tích hợp tùy chọn; để trống nếu dự án không sử dụng.
DATABASE_URL=
SENTRY_DSN=
