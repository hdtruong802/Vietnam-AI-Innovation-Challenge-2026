# Sao chép file này thành .env cho máy cục bộ. Không commit file .env.
# Chỉ điền secret tại máy/deployment tương ứng; không gửi secret qua issue hoặc PR.

APP_ENV=development
# Frontend/local legacy port. Backend uses API_PORT below.
APP_PORT=3000

# Backend FastAPI runtime. `fixture` is development-only and must never run in production.
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_INTAKE_CHARS=500
MAX_BODY_BYTES=65536
# MVP demo: set `demo_pack`. Kill switch defaults keep retrieval and LLM off.
PROCEDURE_DATA_MODE=fixture
RAG_MODE=disabled
LLM_MODE=disabled
LEGACY_RAG_ENABLED=false

# Demo-only K1 simulation (xem D-013/D-019 trong docs/ai/DECISIONS.md).
# Mac dinh false: giu fail-closed truoc K1 nguoi thuc. Chi bat true tren may
# demo cuc bo de xem full flow (form/steps/validate) tren du lieu RAG thuc;
# TUYET DOI KHONG bat tren production/public deploy.
RAG_DEMO_K1_APPROVED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# LLM Gateway hiện tại. Không ghi key thật ở đây.
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=
AI_TIMEOUT_SECONDS=8

# Alias tương thích với stack OpenAI/RAG cũ. Gateway mới vẫn đọc các biến
# này nếu AI_API_KEY để trống; legacy RAG chỉ chạy khi bật flag rõ ràng.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=20

SENTRY_DSN=
