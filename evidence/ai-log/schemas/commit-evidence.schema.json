{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/ai-log/commit-evidence.schema.json",
  "title": "CommitEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "ai_log_id",
    "created_at",
    "member_id",
    "branch",
    "parent_commit",
    "task_records",
    "prompt_ids",
    "tools",
    "capture_status",
    "warnings",
    "operation"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_type": { "const": "commit_evidence" },
    "ai_log_id": { "type": "string", "pattern": "^log-[0-9a-f]{24}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "member_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "branch": { "type": "string", "minLength": 1 },
    "parent_commit": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40,64}$" },
    "task_records": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
    "prompt_ids": { "type": "array", "items": { "type": "string", "pattern": "^prompt-[0-9a-f]{24}$" }, "uniqueItems": true },
    "tools": { "type": "array", "items": { "enum": ["codex", "claude", "cursor", "antigravity"] }, "uniqueItems": true },
    "capture_status": { "enum": ["complete", "warning", "no_new_prompt", "manual", "git_operation"] },
    "warnings": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "operation": { "enum": ["commit", "merge", "revert", "amend"] },
    "replaces_ai_log": { "type": ["string", "null"], "pattern": "^log-[0-9a-f]{24}$" }
  }
}
