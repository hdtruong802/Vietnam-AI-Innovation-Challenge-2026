# Sao chép file này thành .env cho máy cục bộ. Không commit file .env.
# Chỉ điền secret tại máy/deployment tương ứng; không gửi secret qua issue hoặc PR.

APP_ENV=development
# Frontend/local legacy port. Backend uses API_PORT below.
APP_PORT=3000

# Backend FastAPI runtime. `fixture` is development-only and must never run in production.
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_INTAKE_CHARS=500
MAX_BODY_BYTES=65536
PROCEDURE_DATA_MODE=fixture
RAG_MODE=disabled
LLM_MODE=disabled
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Cấu hình AI tùy kiến trúc đã chốt. Không ghi key thật ở đây.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=20

# Tích hợp tùy chọn; để trống nếu dự án không sử dụng.
DATABASE_URL=
SENTRY_DSN=
