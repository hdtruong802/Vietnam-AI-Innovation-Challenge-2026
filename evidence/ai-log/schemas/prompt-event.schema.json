{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/ai-log/prompt-event.schema.json",
  "title": "PromptEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "prompt_id",
    "occurred_at",
    "captured_at",
    "member_id",
    "tool",
    "event",
    "prompt",
    "prompt_preview",
    "model",
    "task_record",
    "branch",
    "workspace_fingerprint",
    "source",
    "sanitization",
    "capture_warnings"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "record_type": { "const": "prompt_event" },
    "prompt_id": { "type": "string", "pattern": "^prompt-[0-9a-f]{24}$" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "captured_at": { "type": "string", "format": "date-time" },
    "member_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "tool": { "enum": ["codex", "claude", "cursor", "antigravity"] },
    "event": { "const": "UserPrompt" },
    "prompt": { "type": "string", "minLength": 1, "maxLength": 100000 },
    "prompt_preview": { "type": "string", "minLength": 1, "maxLength": 280 },
    "model": { "type": ["string", "null"] },
    "task_record": { "type": "string", "minLength": 1 },
    "branch": { "type": "string", "minLength": 1 },
    "workspace_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_hash", "adapter", "adapter_version"],
      "properties": {
        "session_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "adapter": { "enum": ["codex", "claude", "cursor", "antigravity", "manual"] },
        "adapter_version": { "const": "1" }
      }
    },
    "sanitization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["redacted", "categories"],
      "properties": {
        "redacted": { "type": "boolean" },
        "categories": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "capture_warnings": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
